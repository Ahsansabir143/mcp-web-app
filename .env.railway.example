# ─────────────────────────────────────────────────────────────────────────────
# Railway environment variable reference — trading-platform-v2
#
# DO NOT commit real values.  This file is documentation only.
# Paste each variable into the Railway dashboard: Project → Variables.
#
# Which panel to use:
#   "Shared Variables" (project level) → applies to all services you tick
#   Individual service → Variables tab → for service-specific keys
# ─────────────────────────────────────────────────────────────────────────────


# ── Database (set at project level, share to all services) ───────────────────
#
# Railway Postgres gives DATABASE_URL in plain postgresql:// form.
# SQLAlchemy async requires the postgresql+asyncpg:// scheme.
# Use Railway variable references to build the correct URL:
#
DATABASE_URL=postgresql+asyncpg://${{Postgres.PGUSER}}:${{Postgres.PGPASSWORD}}@${{Postgres.PGHOST}}:${{Postgres.PGPORT}}/${{Postgres.PGDATABASE}}
#
# Services that need DATABASE_URL:
#   migrate, analytics, strategy-service, execution, mcp-server, gateway-api
# binance-ingest and normalizer do NOT need DATABASE_URL.


# ── Redis (set at project level, share to relevant services) ─────────────────
#
REDIS_URL=${{Redis.REDIS_URL}}
#
# Services that need REDIS_URL:
#   binance-ingest, normalizer, analytics, strategy-service,
#   execution, mcp-server, gateway-api
# migrate does NOT need REDIS_URL.


# ── Core application settings (share to all 7 app services) ──────────────────

# Runtime environment label — use "staging" for first Railway deploy
ENVIRONMENT=staging

# Must stay "paper" for the initial deploy. Do NOT change to "live".
TRADING_MODE=paper

LOG_LEVEL=INFO

# AES-256-GCM key used by execution service to encrypt/decrypt stored credentials.
# Required by execution service. Must be the same value if you ever restore the DB.
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=REPLACE_WITH_64_HEX_CHARS


# ── MCP server (service-specific — set on mcp-server only) ───────────────────

# X-API-Key required for all /sse and /messages requests
# Generate with: python -c "import secrets; print(secrets.token_urlsafe(32))"
MCP_API_KEY=REPLACE_WITH_SECURE_RANDOM_KEY


# ── Gateway API (service-specific — set on gateway-api only) ─────────────────

# X-API-Key required for all /api/* routes except /api/health
GATEWAY_API_KEY=REPLACE_WITH_SECURE_RANDOM_KEY

# X-API-Key required for all /api/ops/* routes (must differ from GATEWAY_API_KEY)
ADMIN_API_KEY=REPLACE_WITH_DIFFERENT_SECURE_RANDOM_KEY


# ── Binance ingest (service-specific — set on binance-ingest only) ────────────
#
# PAPER MODE: Leave API keys EMPTY.
# Market data WebSocket is public and needs no credentials.
# Populating keys here would allow live order placement — do not do this yet.
#
BINANCE_API_KEY=
BINANCE_API_SECRET=
BINANCE_FUTURES_API_KEY=
BINANCE_FUTURES_API_SECRET=

# Set to "true" to use Binance Testnet WebSocket endpoints instead of production.
# Testnet has lower data quality; leave "false" for real market data in paper mode.
BINANCE_USE_TESTNET=false

# Comma-separated list of Binance stream names to subscribe to.
# REQUIRED — without this, no market data flows and pipeline produces nothing.
# Format: <symbol>@<streamType>  (lowercase symbol)
# Example set for BTC + ETH spot paper trading:
SPOT_STREAMS=btcusdt@aggTrade,btcusdt@depth5@100ms,ethusdt@aggTrade,ethusdt@depth5@100ms

# Leave empty unless you want futures market data (not needed for spot paper mode)
FUTURES_STREAMS=


# ── Optional tuning (Railway default PORT is injected automatically) ──────────
#
# Do NOT set PORT manually — Railway injects it and each Dockerfile CMD reads
# ${PORT:-<default>}. Overriding PORT here would conflict with Railway routing.
#
# These can be left unset; service configs have safe defaults:
#
# REDIS_STREAM_MAX_LEN=50000        # max messages retained per stream
# DATABASE_POOL_SIZE=10
# DATABASE_MAX_OVERFLOW=20
