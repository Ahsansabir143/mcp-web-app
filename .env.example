# ── Database ──────────────────────────────────────────────────
DATABASE_URL=postgresql+asyncpg://postgres:password@localhost:5432/trading_platform
DATABASE_POOL_SIZE=10
DATABASE_MAX_OVERFLOW=20

# ── Redis ─────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0
REDIS_STREAM_MAX_LEN=50000

# ── Binance ───────────────────────────────────────────────────
BINANCE_API_KEY=
BINANCE_API_SECRET=
BINANCE_FUTURES_API_KEY=
BINANCE_FUTURES_API_SECRET=
# Binance testnet (set to 1 for paper trading against testnet)
BINANCE_USE_TESTNET=0

# ── Application ───────────────────────────────────────────────
ENVIRONMENT=dev
TRADING_MODE=paper
LOG_LEVEL=INFO

# ── Security ──────────────────────────────────────────────────
SECRET_KEY=change-me-in-production-use-openssl-rand-hex-32
EXCHANGE_SECRET_ENCRYPTION_KEY=

# ── MCP Server ────────────────────────────────────────────────
MCP_BASE_URL=http://localhost:8003
MCP_OAUTH_CLIENT_ID=
MCP_JWT_SECRET=change-me-mcp-jwt-secret

# ── Anthropic ─────────────────────────────────────────────────
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-6

# ── Service ports ─────────────────────────────────────────────
BINANCE_INGEST_PORT=8001
NORMALIZER_PORT=8002
ANALYTICS_PORT=8003
STRATEGY_PORT=8004
EXECUTION_PORT=8005
MCP_SERVER_PORT=8006
GATEWAY_API_PORT=8000
